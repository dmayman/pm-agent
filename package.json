{
  "name": "@dmayman/pm-agent",
  "version": "0.2.0",
  "description": "A Claude Code plugin that makes Linear your source of truth: a PM agent and /pm:* commands that scope ideas into tickets, sequence work, and keep coding sessions from colliding.",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "pm-agent": "bin/pm-agent.js"
  },
  "scripts": {
    "dev": "node bin/pm-agent.js dev",
    "reload": "node bin/pm-agent.js reload",
    "validate": "node bin/pm-agent.js validate",
    "version": "node scripts/sync-plugin-version.mjs && git add plugins/pm/.claude-plugin/plugin.json",
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true"
  },
  "files": [
    "bin",
    ".claude-plugin",
    "plugins"
  ],
  "keywords": [
    "claude-code",
    "claude-plugin",
    "project-management",
    "pm",
    "linear",
    "agent"
  ],
  "author": "David Mayman",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dmayman/pm-agent.git"
  },
  "engines": {
    "node": ">=18"
  }
}
